# Copy to /etc/nara001/nara001.env, replace both secrets, then:
#   chown root:nara001 /etc/nara001/nara001.env
#   chmod 0640 /etc/nara001/nara001.env
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-characters
CAPTCHA_SECRET=replace-with-at-least-32-random-characters
NARA_DATA_DIR=/var/lib/nara001
NARA_DB_PATH=/var/lib/nara001/nara001.sqlite
NARA_MEDIA_DIR=/var/lib/nara001/media
